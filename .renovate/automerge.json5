{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto merge container digests",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["digest"],
      matchPackageNames: [
        "ghcr.io/home-operations/**",
        "ghcr.io/bjw-s-labs/**",
      ],
      automerge: true,
    },
    {
      description: "Auto merge minors and patches",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: [
        "/kube-prometheus-stack/",
        "ghcr.io/mogenius/helm-charts/renovate-operator",
      ],
      automerge: true,
      automergeType: "pr",
    },
    {
      description: "Auto-merge high-cadence packages weekly",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: [
        "ghcr.io/renovatebot/renovate",
        "ghcr.io/emberstack/helm-charts/reflector",
        "ghcr.io/mogenius/helm-charts/renovate-operator",
      ],
      schedule: ["before 6am on Monday"],
    },
  ],
}
