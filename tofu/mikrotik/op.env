# Loaded by `op run --env-file=op.env -- ...`. Values are 1Password references,
# safe to commit.

AWS_ACCESS_KEY_ID=op://kubernetes/ovh-tofu-state/AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=op://kubernetes/ovh-tofu-state/AWS_SECRET_ACCESS_KEY

TF_VAR_routeros_url=https://192.168.1.2
TF_VAR_routeros_insecure=true
TF_VAR_routeros_username=op://kubernetes/mkt-admin/username
TF_VAR_routeros_password=op://kubernetes/mkt-admin/password

TF_VAR_user_password_admin=op://kubernetes/mkt-admin/password
TF_VAR_user_password_mktxp_user=op://kubernetes/mktxp_user/password
TF_VAR_user_password_wg_portal=op://kubernetes/wg-portal/mikrotik_password
TF_VAR_user_password_homepage=op://kubernetes/mkt-homepage/password
